# Server
PORT=3000
NODE_ENV=development

# Frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:4200

# PostgreSQL — use DATABASE_URL or discrete values
# Local development (Laragon): 127.0.0.1
# Docker Compose network: db
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pcmazing_site

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pcmazing_site
DB_USER=postgres
DB_PASSWORD=postgres

# Schema (defaults to public)
DB_SCHEMA=public

# SSL for managed Postgres / Supabase poolers
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Connection mode: local | supabase-pooler | supabase-direct (auto-detected from URL if omitted)
# DB_CONNECTION_MODE=supabase-pooler

# Supabase: use DATABASE_URL for pooler + DATABASE_DIRECT_URL for migrations/setup
# See .env.supabase.example

# Optional: require x-setup-key header on /setup routes
# SETUP_API_KEY=your-secret-setup-key

# Admin authentication
ADMIN_STAFF_PASSCODE=pcmazing@2026
ADMIN_STAFF_GATE_EXPIRES_IN=8h
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h
