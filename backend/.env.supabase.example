# Server
PORT=3000
NODE_ENV=production

CORS_ORIGINS=https://your-production-domain.com

# ─── Supabase: Transaction Pooler (use for API / app queries) ───
# Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Supabase: Direct connection (use for migrations / setup) ───
# Dashboard → Project Settings → Database → Connection string → Direct connection
DATABASE_DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DB_SCHEMA=public
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_MODE=supabase-pooler

# Optional: require x-setup-key header on /setup routes
# SETUP_API_KEY=your-secret-setup-key
